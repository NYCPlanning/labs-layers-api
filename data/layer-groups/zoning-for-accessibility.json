{
  "id": "zoning-for-accessibility",
  "legend": {
    "label": "Zoning For Accessibility",
    "tooltip": "Transit-adjacent areas where applicable developments and enlargements require additional consultation with the MTA or relevant transit agencies.",
    "infolink": "https://zr.planning.nyc.gov/article-vi/chapter-6"
  },
  "layers": [
    {
      "before": "place_state",
      "style": {
        "id": "zfa-line",
        "type": "line",
        "source": "supporting-zoning",
        "source-layer": "zoning-for-accessibility",
        "paint": {
          "line-width": {
            "stops": [
              [
                11,
                1
              ],
              [
                12,
                3
              ]
            ]
          },
          "line-color": "#DA02C8",
          "line-dasharray": [
            1,
            1
          ]
        }
      }
    },
    {
      "highlightable": true,
      "clickable": true,
      "tooltipable": true,
      "tooltipTemplate": "Transit-adjacent area - {{{zfa_id}}} Station",
      "style": {
        "id": "zfa-fill",
        "type": "fill",
        "source": "supporting-zoning",
        "source-layer": "zoning-for-accessibility",
        "paint": {
          "fill-color": "rgba(218, 2, 200, 0.20)",
          "fill-antialias": true
        }
      }
    }
  ]
}